---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { thinSlice } from '../../../data/thin-slice';

export function getStaticPaths() {
  return thinSlice.slices.map((slice) => ({
    params: { state: thinSlice.state.slug, geo: slice.geo.slug },
    props: { slice }
  }));
}

const { slice } = Astro.props;
const statePath = `/${thinSlice.state.slug}/`;
const categoryPath = `/${thinSlice.state.slug}/${slice.geo.slug}/business-directory/${slice.category.slug}/`;
---
<BaseLayout title={`${slice.geo.name} Geo Hub | MarketGrid`}>
  <nav aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href={statePath}>{thinSlice.state.name}</a></li>
      <li aria-current="page">{slice.geo.name}</li>
    </ol>
  </nav>
  <h1>{slice.geo.name}</h1>
  <p>Geo hub root with onward navigation into the business directory category slice.</p>
  <a class="cta" href={categoryPath}>Browse {slice.category.name}</a>
</BaseLayout>
