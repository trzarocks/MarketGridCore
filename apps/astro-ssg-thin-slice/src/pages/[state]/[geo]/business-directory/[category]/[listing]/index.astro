---
import BaseLayout from '../../../../../../layouts/BaseLayout.astro';
import { thinSlice } from '../../../../../../data/thin-slice';

export function getStaticPaths() {
  const paths = [];
  for (const slice of thinSlice.slices) {
    for (const listing of slice.listings) {
      paths.push({
        params: {
          state: thinSlice.state.slug,
          geo: slice.geo.slug,
          category: slice.category.slug,
          listing: listing.slug
        },
        props: { slice, listing }
      });
    }
  }
  return paths;
}

const { slice, listing } = Astro.props;
const statePath = `/${thinSlice.state.slug}/`;
const geoPath = `/${thinSlice.state.slug}/${slice.geo.slug}/`;
const categoryPath = `/${thinSlice.state.slug}/${slice.geo.slug}/business-directory/${slice.category.slug}/`;
const telHref = `tel:${listing.phone.replace(/[^\d]/g, '')}`;
---
<BaseLayout title={`${listing.name} | MarketGrid`}>
  <nav aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href={statePath}>{thinSlice.state.name}</a></li>
      <li><a href={geoPath}>{slice.geo.name}</a></li>
      <li><a href={categoryPath}>{slice.category.name}</a></li>
      <li aria-current="page">{listing.name}</li>
    </ol>
  </nav>
  <h1>{listing.name}</h1>
  <p>{listing.address}</p>
  <p>{listing.phone}</p>
  <a class="cta" href={telHref}>Call Primary Contact</a>
</BaseLayout>
