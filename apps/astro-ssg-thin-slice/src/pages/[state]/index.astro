---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { thinSlice } from '../../data/thin-slice';

export function getStaticPaths() {
  return [{ params: { state: thinSlice.state.slug } }];
}

const geoLinks = thinSlice.slices.map((slice) => ({
  name: slice.geo.name,
  href: `/${thinSlice.state.slug}/${slice.geo.slug}/`
}));
---
<BaseLayout title={`${thinSlice.state.name} | MarketGrid`}>
  <nav aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li aria-current="page">{thinSlice.state.name}</li>
    </ol>
  </nav>
  <h1>{thinSlice.state.name}</h1>
  <p>State entry page for governed geo slices.</p>
  <ul>
    {geoLinks.map((geo) => (
      <li><a href={geo.href}>{geo.name}</a></li>
    ))}
  </ul>
</BaseLayout>
