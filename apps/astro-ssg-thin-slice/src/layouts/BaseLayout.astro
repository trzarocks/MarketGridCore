---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      :root { font-family: sans-serif; }
      body { margin: 0; line-height: 1.5; }
      main { max-width: 880px; margin: 0 auto; padding: 24px; }
      nav ol { display: flex; gap: 8px; list-style: none; padding: 0; }
      a { color: #0b4c8c; }
      .cta { display: inline-block; background: #0b4c8c; color: #fff; padding: 10px 14px; text-decoration: none; border-radius: 6px; }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
